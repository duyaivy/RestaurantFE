NEXT_PUBLIC_API_ENDPOINT=your-backend-endpoint
NEXT_PUBLIC_URL=your-public-url

# Text-to-Speech (TTS) System Configuration
# Client-side text truncation limit (prevent large API calls/quota usage)
NEXT_PUBLIC_TTS_MAX_CHARS=1000

# Server-side maximum character validation limit
TTS_MAX_CHARS=1000

# FPT AI TTS Configuration (Used for Vietnamese voice guide)
# Get your key at https://fpt.ai/tts
FPT_AI_API_KEY=your_fpt_ai_api_key_here

# FPT AI TTS voice options: banmai (North Female), leminh (North Male), dynamic (Central Male), lannhi (South Female), etc.
FPT_TTS_VOICE=banmai

# FPT AI TTS voice speed (-3 to 3, default is 0)
FPT_TTS_SPEED=0

# FPT AI TTS response format: mp3, wav, etc.
FPT_TTS_FORMAT=mp3